	"components": {
		"schemas": {
			"AgentJobsResponse": {
				"properties": {
					"count": {
						"minimum": 0,
						"type": "integer"
					},
					"jobs": {
						"type": "string"
					},
					"total": {
						"type": "integer"
					}
				},
				"required": [
					"jobs",
					"count",
					"total"
				],
				"type": "object"
			},
			"AgentResponse": {
				"properties": {
					"agent": {
						"type": "string"
					},
					"jobs": {
						"type": "string"
					}
				},
				"required": [
					"agent",
					"jobs"
				],
				"type": "object"
			},
			"AgentsResponse": {
				"properties": {
					"agents": {
						"items": {
							"additionalProperties": true,
							"type": "object"
						},
						"type": "array"
					},
					"count": {
						"minimum": 0,
						"type": "integer"
					},
					"total": {
						"type": "integer"
					}
				},
				"required": [
					"agents",
					"count",
					"total"
				],
				"type": "object"
			},
			"AnalyticsAgentLeaderboardResponse": {
				"properties": {
					"count": {
						"minimum": 0,
						"type": "integer"
					},
					"leaderboard": {
						"items": {
							"additionalProperties": true,
							"type": "object"
						},
						"type": "array"
					},
					"summary": {
						"properties": {
							"jobs_in_flight": {
								"type": "string"
							},
							"jobs_paid": {
								"type": "integer"
							},
							"jobs_rejected": {
								"type": "integer"
							},
							"jobs_total": {
								"type": "integer"
							},
							"total_escrow": {
								"type": "number"
							}
						},
						"required": [
							"total_escrow",
							"jobs_total",
							"jobs_paid",
							"jobs_rejected",
							"jobs_in_flight"
						],
						"type": "object"
					},
					"total": {
						"type": "integer"
					}
				},
				"required": [
					"leaderboard",
					"count",
					"total",
					"summary"
				],
				"type": "object"
			},
			"AnalyticsBridgeFlowResponse": {
				"properties": {
					"by_chain": {
						"additionalProperties": true,
						"type": "object"
					},
					"inbound_count": {
						"type": "integer"
					},
					"inbound_vol": {
						"type": "number"
					},
					"net_flow": {
						"type": "number"
					},
					"outbound_count": {
						"type": "integer"
					},
					"outbound_vol": {
						"type": "number"
					},
					"snapshot_at": {
						"type": "integer"
					},
					"window": {
						"type": "string"
					}
				},
				"required": [
					"window",
					"inbound_vol",
					"inbound_count",
					"outbound_vol",
					"outbound_count",
					"net_flow",
					"by_chain",
					"snapshot_at"
				],
